APP_NAME=LaraChat
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Banco de dados ──────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=larachat
DB_USERNAME=larachat
DB_PASSWORD=secret

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

# ─── Cache / Sessão / Filas ──────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

# ─── Broadcast (Reverb) ──────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=larachat
REVERB_APP_KEY=larachat-key
REVERB_APP_SECRET=larachat-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ─── Storage (MinIO local / S3 produção) ─────────────────────────────────────
FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=larachat
AWS_SECRET_ACCESS_KEY=larachat_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=larachat
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── E-mail (Mailpit local) ──────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@larachat.local"
MAIL_FROM_NAME="${APP_NAME}"

MAILPIT_PORT=1025
MAILPIT_DASHBOARD_PORT=8025

# ─── Horizon ────────────────────────────────────────────────────────────────
HORIZON_PREFIX=larachat_horizon:

VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALGO=HS256

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
